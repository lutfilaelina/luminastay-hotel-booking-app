<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.luminastay">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/logo_app"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/logo_app_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LuminaStay">

        <!-- Splash Screen -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.LuminaStay.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />

        <!-- Register Activity -->
        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false" />

        <!-- Main Activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- Room List Activity -->
        <activity
            android:name=".activities.RoomListActivity"
            android:exported="false" />

        <!-- Room Detail Activity -->
        <activity
            android:name=".activities.RoomDetailActivity"
            android:exported="false" />

        <!-- Booking History Activity -->
        <activity
            android:name=".activities.BookingHistoryActivity"
            android:exported="false" />

        <!-- Layanan Activity -->
        <activity
            android:name=".activities.LayananActivity"
            android:exported="false" />

        <!-- Riwayat Layanan Activity -->
        <activity
            android:name=".activities.RiwayatLayananActivity"
            android:exported="false" />

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="YOUR_GOOGLE_MAPS_API_KEY" />

    </application>

</manifest>